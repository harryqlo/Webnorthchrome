# ═══════════════════════════════════════════════════════════════
# CONFIGURACIÓN LOCAL - NO COMPARTIR NI COMMITEAR
# ═══════════════════════════════════════════════════════════════

# Ambiente
FLASK_ENV=development
FLASK_DEBUG=False

# Base de datos
DATABASE_PATH=system/system.db

# Logging
LOG_LEVEL=INFO

# Secretos (CAMBIAR EN PRODUCCIÓN)
SECRET_KEY=north-chrome-dev-secret-key-change-in-production-12345
JWT_SECRET_KEY=north-chrome-jwt-secret-key-change-in-production-12345

# CORS
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,http://192.168.*.*

# Sesión
SESSION_TIMEOUT=480

# IMPORTANTE: Esta archivo NO debe ser commiteado a Git
# Agregar a .gitignore: .env
